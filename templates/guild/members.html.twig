{% extends 'base.html.twig' %}

{% block title %}Membres de la guilde{% endblock %}

{% block body %}
<div class="container py-4">

    <h1 class="mb-2">👥 Membres de la guilde</h1>
    <p class="mb-4">
        Découvrez les membres TheWinners (grade, avatar, classe et spécialisation).
    </p>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a class="btn btn-sm {{ role is empty ? 'btn-danger' : 'btn-outline-danger' }}"
           href="{{ path('guild_members') }}">
            Tous
        </a>

        <a class="btn btn-sm {{ role == 'tank' ? 'btn-danger' : 'btn-outline-danger' }}"
           href="{{ path('guild_members', { role: 'tank' }) }}">
            🛡️ Tank
        </a>

        <a class="btn btn-sm {{ role == 'heal' ? 'btn-danger' : 'btn-outline-danger' }}"
           href="{{ path('guild_members', { role: 'heal' }) }}">
            ✨ Heal
        </a>

        <a class="btn btn-sm {{ role == 'dps' ? 'btn-danger' : 'btn-outline-danger' }}"
           href="{{ path('guild_members', { role: 'dps' }) }}">
            ⚔️ DPS
        </a>
    </div>

    {% set classIcons = {
        'Guerrier': 'images/classes/warrior.png',
        'Paladin': 'images/classes/paladin.png',
        'Chasseur': 'images/classes/hunter.png',
        'Voleur': 'images/classes/rogue.png',
        'Prêtre': 'images/classes/priest.png',
        'Chaman': 'images/classes/shaman.png',
        'Mage': 'images/classes/mage.png',
        'Démoniste': 'images/classes/warlock.png',
        'Druide': 'images/classes/druid.png',
        'Chevalier de la mort': 'images/classes/deathknight.png'
    } %}

    {% if members is empty %}
        <div class="alert alert-secondary">
            Aucun membre pour le moment.
        </div>
    {% else %}
        <div class="row g-3">
            {% for m in members %}
                {% set u = m.user %}
                {% set avatarPath = u.avatar ? asset(u.avatar) : asset('images/default-avatar.png') %}
                {% set cls = m.class ?: null %}

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card bg-dark border-danger shadow-sm h-100">
                        <div class="card-body d-flex gap-3">

                            <img src="{{ avatarPath }}"
                                 alt="Avatar {{ u.pseudo }}"
                                 style="width:64px;height:64px;border-radius:12px;object-fit:cover;border:1px solid rgba(255,255,255,.2);">

                            <div class="flex-grow-1">

                                <div class="d-flex align-items-center justify-content-between gap-2">
                                    <div class="fw-semibold text-white">
                                        {{ u.pseudo }}
                                    </div>

                                    <span class="badge bg-danger">
                                        {{ u.guildRank.label() }}
                                    </span>
                                </div>

                                <div class="mt-2 small text-light" style="opacity:.95;">

                                    <div class="mb-1">
                                        <span class="text-light">Personnage :</span>
                                        <span class="text-white">{{ m.name ?: '—' }}</span>

                                        {% if m.isMain %}
                                            <span class="badge bg-success ms-2">Main</span>
                                        {% endif %}
                                    </div>

                                    <div class="mb-1 d-flex align-items-center gap-2">
                                        <span class="text-light">Classe :</span>

                                        {% if cls and classIcons[cls] is defined %}
                                            <img src="{{ asset(classIcons[cls]) }}"
                                                 alt="Icône {{ cls }}"
                                                 style="width:24px;height:24px;object-fit:contain;">
                                        {% endif %}

                                        <span class="text-white">{{ cls ?? '—' }}</span>
                                    </div>

                                    <div class="mb-1">
                                        <span class="text-light">Spé :</span>
                                        <span class="text-white">{{ m.spec ?: '—' }}</span>
                                    </div>

                                    {% if m.combatRole %}
                                        <div class="mt-2">
                                            <span class="badge
                                                {% if m.combatRole.value == 'tank' %}
                                                    bg-primary
                                                {% elseif m.combatRole.value == 'heal' %}
                                                    bg-success
                                                {% else %}
                                                    bg-warning text-dark
                                                {% endif %}
                                            ">
                                                {% if m.combatRole.value == 'tank' %}
                                                    🛡️ {{ m.combatRole.label() }}
                                                {% elseif m.combatRole.value == 'heal' %}
                                                    ✨ {{ m.combatRole.label() }}
                                                {% else %}
                                                    ⚔️ {{ m.combatRole.label() }}
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% endif %}

                                    {% if m.profession1 or m.profession2 %}
                                        <div class="mt-2">
                                            <span class="text-light">Métiers :</span>
                                            <span class="text-white">
                                                {{ m.profession1 ?: '—' }}
                                                {% if m.profession1 and m.profession2 %} / {% endif %}
                                                {{ m.profession2 ?: '' }}
                                            </span>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 pt-0">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="small text-muted">
                                    Perso #{{ m.id }} — User #{{ u.id }}
                                </div>

                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('admin_personnage_edit', { id: m.id }) }}"
                                       class="btn btn-sm btn-warning">
                                        Modifier
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}