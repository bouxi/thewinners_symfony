{% extends 'base.html.twig' %}

{% block title %}Calendrier des raids{% endblock %}

{% block body %}
<div class="container py-4">

    {# ===== Header calendrier ===== #}
    <div class="d-flex justify-content-between align-items-center mb-3 calendar-topbar">
        <div class="calendar-title-wrap">
            <h1 class="mb-0 text-center calendar-title">Calendrier des raids</h1>
            <div class="text-muted small calendar-month">
                {{ month|format_datetime(pattern='MMMM yyyy', locale='fr')|capitalize }}
            </div>
        </div>

        <div class="d-flex gap-2 calendar-actions">
            <a class="btn btn-outline-light calendar-nav-btn"
               href="{{ path('raids_calendar', {month: prevMonth|date('Y-m')}) }}">←</a>

            <a class="btn btn-outline-light calendar-nav-btn"
               href="{{ path('raids_calendar', {month: nextMonth|date('Y-m')}) }}">→</a>

            <button type="button"
                    class="btn btn-danger calendar-create-btn"
                    id="openCreateRaidModal">
                Créer un raid
            </button>
        </div>
    </div>

    {% set startOfGrid = (month|date('N') - 1) %}
    {% set daysInMonth = month|date('t') %}
    {% set totalCells = 42 %}

    {# ===== Jours de la semaine ===== #}
    <div class="calendar-weekdays">
        {% for dayName in ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'] %}
            <div class="calendar-weekday">{{ dayName }}</div>
        {% endfor %}
    </div>

    {# ===== Grille calendrier ===== #}
    <div class="calendar-grid mt-2">
        {% for i in 0..(totalCells-1) %}
            {% set dayNumber = i - startOfGrid + 1 %}
            {% set isInMonth = dayNumber >= 1 and dayNumber <= daysInMonth %}

            {% if isInMonth %}
                {% set dateKey = month|date('Y-m') ~ '-' ~ '%02d'|format(dayNumber) %}
                {% set raids = raidsByDay[dateKey] ?? [] %}
            {% else %}
                {% set dateKey = null %}
                {% set raids = [] %}
            {% endif %}

            <div class="calendar-cell {% if not isInMonth %}calendar-cell--out{% endif %}">
                <div class="calendar-cell__top">
                    <div class="calendar-day">
                        {% if isInMonth %}{{ dayNumber }}{% else %}—{% endif %}
                    </div>
                    <div class="calendar-date">
                        {% if isInMonth %}{{ dateKey }}{% endif %}
                    </div>
                </div>

                <div class="calendar-cell__content">
                    {% if raids|length > 0 %}
                        {% for raid in raids %}
                            {% set raidLabel = raidLabels[raid.raidKey] ?? raid.title %}

                            <a class="calendar-raid"
                               href="{{ path('raids_show', {id: raid.id}) }}">

                                <div class="calendar-raid__title">
                                    {{ raidLabel }}
                                </div>

                                {% if raid.title and raid.title != raidLabel %}
                                    <div class="calendar-raid__subtitle small text-muted">
                                        {{ raid.title }}
                                    </div>
                                {% endif %}

                                <div class="calendar-raid__time">
                                    {{ raid.startsAt|date('H:i') }} → {{ raid.endsAt|date('H:i') }}
                                </div>
                            </a>
                        {% endfor %}
                    {% else %}
                        <div class="calendar-empty">—</div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}

{% block modals %}
<div class="modal fade" id="createRaidModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark border-danger">
            <div class="modal-header">
                <h5 class="modal-title text-white">Créer un raid</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-light">

                {{ form_start(createForm) }}
                {{ form_errors(createForm) }}

                {{ form_row(createForm.raidKey) }}
                {{ form_row(createForm.title) }}
                {{ form_row(createForm.startsAt) }}
                {{ form_row(createForm.endsAt) }}
                {{ form_row(createForm.description) }}

                {{ form_rest(createForm) }}

                <button class="btn btn-danger w-100 mt-3">
                    Valider la création
                </button>

                {{ form_end(createForm) }}

            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('openCreateRaidModal');
    const modalEl = document.getElementById('createRaidModal');

    if (btn && modalEl) {
        btn.addEventListener('click', () => {
            new bootstrap.Modal(modalEl).show();
        });
    }

    const wasSubmitted = {{ createForm.vars.submitted ? 'true' : 'false' }};
    const isValid = {{ createForm.vars.valid ? 'true' : 'false' }};

    if (wasSubmitted && !isValid) {
        new bootstrap.Modal(modalEl).show();
    }
});
</script>
{% endblock %}