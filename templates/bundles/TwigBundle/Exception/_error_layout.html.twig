{% extends 'base.html.twig' %}

{% block body %}
    <section class="py-5 min-vh-100 d-flex align-items-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-7">
                    <div class="card border-0 shadow-lg bg-dark text-white overflow-hidden">
                        <div class="card-body p-4 p-md-5 text-center">

                            <div class="mb-4">
                                <span class="badge rounded-pill text-bg-danger px-3 py-2 fs-6">
                                    TheWinners
                                </span>
                            </div>

                            {% block error_content %}{% endblock %}

                            <hr class="my-4 border-secondary">

                            <div class="d-flex flex-wrap justify-content-center gap-3">
                                <a href="{{ path('app_home') }}" class="btn btn-danger px-4">
                                    Retour à l’accueil
                                </a>

                                <a href="javascript:history.back()" class="btn btn-outline-light px-4">
                                    Revenir en arrière
                                </a>
                            </div>
                        </div>
                    </div>

                    <p class="text-center text-light mt-3 small opacity-75">
                        Guilde Horde — TheWinners
                    </p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}