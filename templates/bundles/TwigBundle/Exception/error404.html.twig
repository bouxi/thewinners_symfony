{% extends 'bundles/TwigBundle/Exception/_error_layout.html.twig' %}

{% block title %}404 - Page introuvable | TheWinners{% endblock %}

{% block error_content %}
    <div class="display-1 fw-bold text-danger mb-3">404</div>

    <h1 class="h2 fw-bold mb-3">Page introuvable</h1>

    <p class="lead text-white-50 mb-4">
        Les éclaireurs de la Horde n’ont trouvé aucune trace de cette page.
        Elle a peut-être été déplacée, supprimée ou l’adresse saisie est incorrecte.
    </p>

    <div class="alert alert-secondary border-0 bg-black bg-opacity-25 text-light mb-0">
        Vérifie l’URL ou retourne vers une zone sûre du site.
    </div>
{% endblock %}