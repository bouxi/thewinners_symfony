{% extends 'bundles/TwigBundle/Exception/_error_layout.html.twig' %}

{% block title %}Erreur | TheWinners{% endblock %}

{% block error_content %}
    <div class="display-1 fw-bold text-danger mb-3">Erreur</div>

    <h1 class="h2 fw-bold mb-3">Une erreur est survenue</h1>

    <p class="lead text-white-50 mb-4">
        Une anomalie a empêché l’affichage correct de cette page.
    </p>

    <div class="alert alert-secondary border-0 bg-black bg-opacity-25 text-light mb-0">
        Merci de réessayer plus tard.
    </div>
{% endblock %}