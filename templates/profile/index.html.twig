{% extends 'base.html.twig' %}
{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="mb-4">Mon profil</h1>

    <div class="row g-3">

        {# ===============================
           INFOS & AVATAR
           =============================== #}
        <div class="col-12 col-lg-6">
            <div class="card bg-black bg-opacity-50 border-danger text-light h-100">
                <div class="card-header border-danger">
                    <strong>Infos & Avatar</strong>
                </div>

                <div class="card-body">

                    <div class="d-flex align-items-center gap-3 mb-3">
                        {% set avatarPath = app.user.avatar
                            ? asset(app.user.avatar)
                            : asset('images/default-avatar.png')
                        %}

                        <img src="{{ avatarPath }}"
                             alt="Avatar"
                             class="rounded-circle"
                             style="width:64px;height:64px;object-fit:cover;border:2px solid rgba(220,53,69,.8);">

                        <div>
                            <div class="fw-bold">{{ app.user.pseudo }}</div>
                            <div class="text-muted small">{{ app.user.email }}</div>
                        </div>
                    </div>

                    {{ form_start(profileForm) }}
                        {{ form_row(profileForm.pseudo) }}
                        {{ form_row(profileForm.avatarFile) }}
                        <button class="btn btn-danger mt-2">Enregistrer</button>
                    {{ form_end(profileForm) }}

                </div>
            </div>
        </div>

    

        {# ===============================
           PERSONNAGE WOW
           =============================== #}
        
        <div class="col-12 col-lg-6">
            <div class="card bg-black bg-opacity-50 border-danger text-light h-100">
                <div class="card-header border-danger">
                    <strong>Personnage (WoW)</strong>
                </div>

                <div class="card-body">
                    <form method="post">
                        <input type="hidden" name="_token_character"
                               value="{{ csrf_token('character_update') }}">

                        <div class="mb-3">
                            <label class="form-label">Nom du personnage</label>
                            <input type="text"
                                   name="characterName"
                                   class="form-control"
                                   value="{{ app.user.characterName }}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Classe</label>
                            <input type="text"
                                   name="characterClass"
                                   class="form-control"
                                   value="{{ app.user.characterClass }}">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Spécialisation</label>
                            <input type="text"
                                   name="characterSpec"
                                   class="form-control"
                                   value="{{ app.user.characterSpec }}">
                        </div>

                        <button class="btn btn-danger">Mettre à jour personnage</button>
                    </form>
                </div>
            </div>
        </div>
        
        {# ===============================
           MOT DE PASSE
           =============================== #}
        <div class="col-12">
            <div class="card bg-black bg-opacity-50 border-danger text-light">
                <div class="card-header border-danger">
                    <strong>Changer mon mot de passe</strong>
                </div>

                <div class="card-body">
                    {{ form_start(passwordForm) }}
                        {{ form_row(passwordForm.currentPassword) }}
                        {{ form_row(passwordForm.newPassword.first) }}
                        {{ form_row(passwordForm.newPassword.second) }}
                        <button class="btn btn-danger mt-2">Mettre à jour</button>
                    {{ form_end(passwordForm) }}
                </div>
            </div>
        </div>

        {# ===============================
           PRÉFÉRENCES
           =============================== #}
           
        <div class="col-8 col-lg-6">
            <div class="card bg-black bg-opacity-50 border-danger text-light h-100">
                <div class="card-header border-danger">
                    <strong>Préférences</strong>
                </div>

                <div class="card-body">
                    <a class="btn btn-sm btn-outline-light" href="{{ path('app_profile_consents') }}">
                        Mes consentements
                    </a>
                </div>
            </div>
        </div>
        

    </div>
</div>
{% endblock %}
