{% extends 'base.html.twig' %}

{% block title %}Mes consentements{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="card bg-dark text-light border-danger shadow-sm">
            <div class="card-header border-danger">
                <h1 class="h3 mb-0">Mes consentements</h1>
            </div>

            <div class="card-body">
                {% if consent %}
                    <div class="table-responsive">
                        <table class="table table-dark table-bordered align-middle">
                            <tbody>
                                <tr>
                                    <th scope="row">Conditions générales acceptées</th>
                                    <td>
                                        {% if consent.termsAccepted %}
                                            <span class="badge text-bg-success">Oui</span>
                                        {% else %}
                                            <span class="badge text-bg-danger">Non</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Date d’acceptation des CGU</th>
                                    <td>
                                        {{ consent.termsAcceptedAt ? consent.termsAcceptedAt|date('d/m/Y H:i') : '—' }}
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Version des CGU</th>
                                    <td>{{ consent.termsVersion ?? '—' }}</td>
                                </tr>

                                <tr>
                                    <th scope="row">Politique de confidentialité acceptée</th>
                                    <td>
                                        {% if consent.privacyAccepted %}
                                            <span class="badge text-bg-success">Oui</span>
                                        {% else %}
                                            <span class="badge text-bg-danger">Non</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Date d’acceptation confidentialité</th>
                                    <td>
                                        {{ consent.privacyAcceptedAt ? consent.privacyAcceptedAt|date('d/m/Y H:i') : '—' }}
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Version confidentialité</th>
                                    <td>{{ consent.privacyVersion ?? '—' }}</td>
                                </tr>

                                <tr>
                                    <th scope="row">Choix cookies</th>
                                    <td>
                                        {% if consent.cookieChoice %}
                                            <span class="badge text-bg-info">{{ consent.cookieChoice }}</span>
                                        {% else %}
                                            <span class="text-muted">Aucun choix enregistré</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Cookies acceptés</th>
                                    <td>
                                        {% if consent.cookiesAccepted %}
                                            <span class="badge text-bg-success">Oui</span>
                                        {% else %}
                                            <span class="badge text-bg-danger">Non</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Date choix cookies</th>
                                    <td>
                                        {{ consent.cookiesAcceptedAt ? consent.cookiesAcceptedAt|date('d/m/Y H:i') : '—' }}
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">Version cookies</th>
                                    <td>{{ consent.cookiesVersion ?? '—' }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <button type="button" id="manage-cookies" class="btn btn-sm btn-outline-primary">
                            Gérer mes cookies
                        </button>
                    </div>
                {% else %}
                    <div class="alert alert-warning mb-0">
                        Aucun consentement n’a encore été enregistré pour votre compte.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}