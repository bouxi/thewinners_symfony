<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}TheWinners — Guilde Horde{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# Google Fonts facultatif #}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    {# Bootstrap 5 via CDN #}
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous"
    >

    {# Ton CSS maison #}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">

    {% block stylesheets %}{% endblock %}

    {# ✅ IMPORTANT si tu utilises AssetMapper/importmap (charge assets/app.js) #}
    {{ importmap('app') }}
</head>

<body class="d-flex flex-column min-vh-100 bg-dark text-light">
<header>
    {% include 'partials/navbar.html.twig' %}
</header>

<main class="flex-fill">
    {% block body %}{% endblock %}
</main>

{# Footer différent selon admin ou non #}
{% if app.request.attributes.get('_route') starts with 'admin_' %}
    {% include 'partials/footer_admin.html.twig' %}
{% else %}
    {% include 'partials/footer.html.twig' %}
{% endif %}

{# ✅ Les modals ici : en bas du body, hors des wrappers => layering stable #}
{% block modals %}{% endblock %}

{# Bootstrap JS via CDN (ok puisque window.bootstrap fonctionne) #}
<script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous"></script>

{% block javascripts %}{% endblock %}

</body>
</html>