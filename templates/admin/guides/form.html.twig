{% extends 'admin/admin_base.html.twig' %}

{% block title %}{{ pageTitle }} | Admin{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="mb-4">
            <h1 class="h2 mb-1">{{ pageTitle }}</h1>
            <p class="text-muted mb-0">
                Rédigez et organisez les contenus du module Guides.
            </p>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                {{ form_start(form) }}
                    <div class="row g-3">
                        <div class="col-12">
                            {{ form_row(form.title) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.slug) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.excerpt) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.content, {
                                attr: {
                                    class: 'js-rich-editor'
                                }
                            }) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.category) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.featuredImageFile) }}

                            {% if guide.featuredImage %}
                                <div class="mt-3">
                                    <p class="small text-muted mb-2">Image actuelle :</p>
                                    <img
                                        src="{{ asset(guide.featuredImage) }}"
                                        alt="Image actuelle du guide"
                                        class="img-fluid rounded border"
                                        style="max-height: 220px;"
                                    >
                                </div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.isPublished) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.publishedAt) }}
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                        <button type="submit" class="btn btn-danger">
                            Enregistrer
                        </button>

                        <a href="{{ path('admin_guides_index') }}" class="btn btn-outline-secondary">
                            Retour à la liste
                        </a>

                        {% if guide.id and guide.isPublished %}
                            <a href="{{ path('guides_show', { slug: guide.slug }) }}"
                               class="btn btn-outline-primary"
                               target="_blank"
                               rel="noopener">
                                Voir la page publique
                            </a>
                        {% endif %}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('/vendor/tinymce/tinymce.min.js') }}"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            console.log('Bloc JS guides chargé');

            const textarea = document.querySelector('textarea.js-rich-editor');
            console.log('Textarea trouvé ?', textarea);

            console.log('TinyMCE disponible ?', typeof tinymce);

            if (!textarea) {
                console.error('Aucun textarea avec la classe js-rich-editor trouvé.');
                return;
            }

            if (typeof tinymce === 'undefined') {
                console.error('TinyMCE n’est pas chargé.');
                return;
            }

            tinymce.init({
                selector: 'textarea.js-rich-editor',
                license_key: 'gpl',
                height: 500,
                menubar: true,
                branding: false,
                promotion: false,
                convert_urls: false,
                browser_spellcheck: true,
                contextmenu: false,
                plugins: 'lists link image table code fullscreen preview',
                toolbar: 'undo redo | blocks | bold italic underline | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link image table | code preview fullscreen'
            });
        });
    </script>
{% endblock %}