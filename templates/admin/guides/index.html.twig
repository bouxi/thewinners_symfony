{% extends 'admin/admin_base.html.twig' %}

{% block title %}Guides | Admin{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <h1 class="h2 mb-1">Guides</h1>
                <p class="text-muted mb-0">
                    Gérez les contenus du module Guides.
                </p>
            </div>

            <div>
                <a href="{{ path('admin_guides_new') }}" class="btn btn-danger">
                    + Nouveau guide
                </a>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <label for="filter-q" class="form-label">Recherche</label>
                        <input
                            type="text"
                            id="filter-q"
                            name="q"
                            class="form-control"
                            value="{{ query }}"
                            placeholder="Titre ou slug..."
                        >
                    </div>

                    <div class="col-md-3">
                        <label for="filter-status" class="form-label">Statut</label>
                        <select id="filter-status" name="status" class="form-select">
                            <option value="">Tous</option>
                            <option value="published" {{ status == 'published' ? 'selected' : '' }}>Publié</option>
                            <option value="draft" {{ status == 'draft' ? 'selected' : '' }}>Brouillon</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label for="filter-category" class="form-label">Catégorie</label>
                        <select id="filter-category" name="category" class="form-select">
                            <option value="">Toutes</option>
                            {% for category in categories %}
                                <option
                                    value="{{ category.id }}"
                                    {{ selectedCategory and selectedCategory.id == category.id ? 'selected' : '' }}
                                >
                                    {{ category.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-md-2 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Filtrer
                        </button>
                    </div>

                    <div class="col-12">
                        <a href="{{ path('admin_guides_index') }}" class="btn btn-outline-secondary btn-sm">
                            Réinitialiser les filtres
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted small">
                {{ total }} guide{{ total > 1 ? 's' : '' }} trouvé{{ total > 1 ? 's' : '' }}
            </div>
        </div>

        {% if guides is not empty %}
            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Titre</th>
                                <th>Catégorie</th>
                                <th>Auteur</th>
                                <th>Statut</th>
                                <th>Publication</th>
                                <th>Mise à jour</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for guide in guides %}
                                <tr>
                                    <td>{{ guide.id }}</td>

                                    <td>
                                        <div class="fw-semibold">{{ guide.title }}</div>
                                        <div class="small text-muted">
                                            <code>{{ guide.slug }}</code>
                                        </div>
                                    </td>

                                    <td>
                                        {% if guide.category %}
                                            {{ guide.category.name }}
                                        {% else %}
                                            <span class="text-muted">Aucune</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if guide.author %}
                                            {{ guide.author.pseudo }}
                                        {% else %}
                                            <span class="text-muted">Non défini</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if guide.isPublished %}
                                            <span class="badge text-bg-success">Publié</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">Brouillon</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if guide.publishedAt %}
                                            {{ guide.publishedAt|date('d/m/Y H:i') }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if guide.updatedAt %}
                                            {{ guide.updatedAt|date('d/m/Y H:i') }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>

                                    <td class="text-end">
                                        <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                                            <a href="{{ path('admin_guides_edit', { id: guide.id }) }}"
                                               class="btn btn-sm btn-outline-primary">
                                                Modifier
                                            </a>

                                            {% if guide.isPublished %}
                                                <a href="{{ path('guides_show', { slug: guide.slug }) }}"
                                                   class="btn btn-sm btn-outline-danger"
                                                   target="_blank"
                                                   rel="noopener">
                                                    Voir
                                                </a>
                                            {% endif %}

                                            <form method="post"
                                                  action="{{ path('admin_guides_delete', { id: guide.id }) }}"
                                                  onsubmit="return confirm('Confirmer la suppression de ce guide ?');"
                                                  class="d-inline">
                                                <input type="hidden"
                                                       name="_token"
                                                       value="{{ csrf_token('delete_guide_' ~ guide.id) }}">

                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Supprimer
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            {% if pages > 1 %}
                <nav class="mt-4" aria-label="Pagination des guides">
                    <ul class="pagination">
                        {% set currentParams = {
                            q: query,
                            status: status,
                            category: selectedCategory ? selectedCategory.id : ''
                        } %}

                        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                            <a class="page-link"
                               href="{{ page > 1 ? path('admin_guides_index', currentParams|merge({ page: page - 1 })) : '#' }}">
                                Précédent
                            </a>
                        </li>

                        {% for p in 1..pages %}
                            <li class="page-item {{ p == page ? 'active' : '' }}">
                                <a class="page-link"
                                   href="{{ path('admin_guides_index', currentParams|merge({ page: p })) }}">
                                    {{ p }}
                                </a>
                            </li>
                        {% endfor %}

                        <li class="page-item {{ page >= pages ? 'disabled' : '' }}">
                            <a class="page-link"
                               href="{{ page < pages ? path('admin_guides_index', currentParams|merge({ page: page + 1 })) : '#' }}">
                                Suivant
                            </a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        {% else %}
            <div class="alert alert-secondary mb-0">
                Aucun guide ne correspond aux filtres sélectionnés.
            </div>
        {% endif %}
    </div>
{% endblock %}