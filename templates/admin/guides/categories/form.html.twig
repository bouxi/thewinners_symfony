{% extends 'admin/admin_base.html.twig' %}

{% block title %}{{ pageTitle }} | Admin{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="mb-4">
            <h1 class="h2 mb-1">{{ pageTitle }}</h1>
            <p class="text-muted mb-0">
                Configurez la structure hiérarchique des guides du site.
            </p>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                {{ form_start(form) }}
                    <div class="row g-3">
                        <div class="col-md-6">
                            {{ form_row(form.name) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.slug) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.description) }}
                        </div>

                        <div class="col-md-4">
                            {{ form_row(form.position) }}
                        </div>

                        <div class="col-md-4">
                            {{ form_row(form.icon) }}
                        </div>

                        <div class="col-md-4">
                            {{ form_row(form.parent) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.isActive) }}
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                        <button type="submit" class="btn btn-danger">
                            Enregistrer
                        </button>

                        <a href="{{ path('admin_guides_categories_index') }}" class="btn btn-outline-secondary">
                            Retour à la liste
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}