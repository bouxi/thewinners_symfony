{% extends 'base.html.twig' %}

{% block title %}Ajouter mon personnage{% endblock %}

{% block body %}
<div class="container py-4">

    <h1 class="mb-3">Ajouter mon personnage (Admin)</h1>

    {% for label, messagesFlash in app.flashes %}
        {% for message in messagesFlash %}
            <div class="alert alert-{{ label }} mb-3">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card bg-dark text-white border-0">
        <div class="card-body">

            {{ form_start(form) }}

                {{ form_row(form.name) }}
                {{ form_row(form.class) }}
                {{ form_row(form.spec) }}

                <button class="btn btn-success mt-2">Enregistrer</button>

                <a class="btn btn-secondary mt-2" href="{{ path('guild_members') }}">
                    Retour
                </a>

            {{ form_end(form) }}

        </div>
    </div>

</div>

{# ✅ On injecte wow depuis le controller, pas via constant() #}
<script id="wow-data" type="application/json">
{{ wow|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }}
</script>

<script>
(function () {
    const wow = JSON.parse(document.getElementById('wow-data').textContent || '{}');

    const classSelect = document.getElementById('{{ form.class.vars.id }}');
    const specSelect  = document.getElementById('{{ form.spec.vars.id }}');

    if (!classSelect || !specSelect) return;

    function resetSpecs() {
        specSelect.innerHTML = '<option value="">— Choisir d’abord une classe —</option>';
        specSelect.disabled = true;
    }

    function fillSpecs(className) {
        const specs = wow[className] || [];
        specSelect.innerHTML = '<option value="">— Choisir une spécialisation —</option>';

        specs.forEach(spec => {
            const opt = document.createElement('option');
            opt.value = spec;
            opt.textContent = spec;
            specSelect.appendChild(opt);
        });

        specSelect.disabled = false;
    }

    classSelect.addEventListener('change', function () {
        const selected = this.value;
        if (!selected || !wow[selected]) return resetSpecs();
        fillSpecs(selected);
    });

    // ✅ init : si une classe est déjà sélectionnée
    if (classSelect.value && wow[classSelect.value]) {
        fillSpecs(classSelect.value);
    } else {
        resetSpecs();
    }
})();
</script>
{% endblock %}