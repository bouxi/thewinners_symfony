{% extends 'base.html.twig' %}

{% block title %}Modifier mon personnage{% endblock %}

{% block body %}
<div class="container py-4">

    <h1 class="mb-3">Modifier mon personnage (Admin)</h1>

    {# ✅ messages flash #}
    {% for label, messagesFlash in app.flashes %}
        {% for message in messagesFlash %}
            <div class="alert alert-{{ label }} mb-3">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card bg-dark text-white border-0">
        <div class="card-body">

            {{ form_start(form) }}

                {{ form_row(form.name) }}
                {{ form_row(form.class) }}
                {{ form_row(form.spec) }}

                {# ✅ champs admin #}
                {{ form_row(form.combatRole) }}
                {{ form_row(form.profession1) }}
                {{ form_row(form.profession2) }}
                {{ form_row(form.isMain) }}
                {{ form_row(form.isPublic) }}

                <button class="btn btn-success mt-2">
                    Enregistrer
                </button>

                <a class="btn btn-secondary mt-2" href="{{ path('guild_members') }}">
                    Retour
                </a>

            {{ form_end(form) }}

        </div>
    </div>

</div>

{# ✅ (temp) on reste sur WowData direct, et ensuite Option B remplacera ce bloc #}
<script id="wow-data" type="application/json">
{{ constant('App\\\\Service\\\\WowData::CLASSES')|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }}
</script>

<script>
(function () {
    const wow = JSON.parse(document.getElementById('wow-data').textContent || '{}');

    const classSelect = document.getElementById('{{ form.class.vars.id }}');
    const specSelect  = document.getElementById('{{ form.spec.vars.id }}');

    if (!classSelect || !specSelect) return;

    function resetSpecs() {
        specSelect.innerHTML = '<option value="">— Choisir d’abord une classe —</option>';
        specSelect.disabled = true;
    }

    function fillSpecs(className, selectedSpec) {
        const specs = wow[className] || [];

        specSelect.innerHTML = '<option value="">— Choisir une spécialisation —</option>';

        specs.forEach(spec => {
            const opt = document.createElement('option');
            opt.value = spec;
            opt.textContent = spec;
            if (selectedSpec && selectedSpec === spec) opt.selected = true;
            specSelect.appendChild(opt);
        });

        specSelect.disabled = false;
    }

    classSelect.addEventListener('change', function () {
        const selectedClass = this.value;
        if (!selectedClass || !wow[selectedClass]) {
            resetSpecs();
            return;
        }
        fillSpecs(selectedClass, null);
    });

    // ✅ init : si déjà une classe en édition, on remplit en gardant la spec actuelle
    const initialClass = classSelect.value;
    const initialSpec  = specSelect.value;

    if (initialClass && wow[initialClass]) {
        fillSpecs(initialClass, initialSpec);
    } else {
        resetSpecs();
    }
})();
</script>
{% endblock %}