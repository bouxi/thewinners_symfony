{% extends 'base.html.twig' %}

{% block title %}Modifier mon personnage{% endblock %}

{% block body %}
<div class="container py-4">

    <h1 class="mb-3">Modifier mon personnage (Admin)</h1>

    {% for label, messagesFlash in app.flashes %}
        {% for message in messagesFlash %}
            <div class="alert alert-{{ label }} mb-3">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div
        class="card bg-dark text-white border-0"
        data-personnage-form
        data-specs-url-template="{{ path('api_wow_specs') ~ '?class=__CLASS__' }}"
        data-class-selector="#{{ form.class.vars.id }}"
        data-spec-selector="#{{ form.spec.vars.id }}"
    >
        <div class="card-body">

            {{ form_start(form) }}

                {{ form_row(form.name) }}
                {{ form_row(form.class) }}
                {{ form_row(form.spec) }}
                {{ form_row(form.combatRole) }}
                {{ form_row(form.profession1) }}
                {{ form_row(form.profession2) }}
                {{ form_row(form.isMain) }}
                {{ form_row(form.isPublic) }}

                <button class="btn btn-success mt-2">
                    Enregistrer
                </button>

                <a class="btn btn-secondary mt-2" href="{{ path('guild_members') }}">
                    Retour
                </a>

            {{ form_end(form) }}

        </div>
    </div>

</div>
{% endblock %}